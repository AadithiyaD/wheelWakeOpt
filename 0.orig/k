FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
#include        "include/initialConditions"

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform $turbulentKE;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    outlet
    {
        type            zeroGradient;
    }
    ground
    {
        type            kqRWallFunction;
        value           $internalField;
    }
    "(wheel|contactPatchSide)"
    {
        type            kqRWallFunction;
        value           $internalField;
    }
    "(top|side1)"
    {
        type            slip;
    }
    symmetry
    {
        type            symmetry;
    }
    
}

