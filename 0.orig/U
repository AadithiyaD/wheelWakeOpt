FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

#include        "include/initialConditions"

internalField   uniform (0 0 0);

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform $flowVelocity;
    }
    outlet
    {
        type            zeroGradient;
    }
    ground
    {
        type            fixedValue;
        value           uniform $flowVelocity;
    }
    "(wheel|contactPatchSide)"
    {
        type            rotatingWallVelocity;
        origin          (0 0.1657 0);
        axis            (0 0 1);
        omega           181.79345706666666;
    }
    "(top|side1)"
    {
        type            slip;
    }
    symmetry
    {
        type            symmetry;
    }
    
}

