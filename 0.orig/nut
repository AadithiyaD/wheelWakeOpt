FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 0;
    }
    outlet
    {
        type            zeroGradient;
    }
    ground
    {
        type            nutUSpaldingWallFunction;
        value           uniform 0;
    }
    "(wheel|contactPatchSide)"
    {
        type            nutUSpaldingWallFunction;
        value           uniform 0;
    }
    "(top|side2|side1)"
    {
        type            slip;
    }
}

