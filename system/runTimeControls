runTimeControl1
{
    type            runTimeControl;
    libs            (utilityFunctionObjects);
    conditions
    {
        condition1
        {
            type            average;
            functionObject  forceCoeffs1;
            fields          (Cd);
            tolerance       4e-6;
            window          15;
            windowType      exact;
            groupID         1; 
        }
        condition2
        {
            type            average;
            functionObject  forceCoeffs1;
            fields          (Cl);
            tolerance       1.5e-6;
            window          35;
            windowType      exact;
            groupID         1; 
        }
    }
    satisfiedAction setTrigger;
    trigger         1;
}

runTimeControl2
{
    type            runTimeControl;
    libs            (utilityFunctionObjects);
    controlMode     trigger;
    triggerStart    1;
    conditions
    {
        condition1
        {
            type            maxDuration;
            duration        100;
        }
    }
    satisfiedAction end;
}

